branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ]; then
  echo "You can't commit directly to main - please check out a branch."
  exit 1
fi

if command -v pnpm >/dev/null 2>&1; then
  pnpm_cmd="pnpm"
else
  pnpm_cmd="npx pnpm"
fi

npx_cmd="npx"

$npx_cmd lint-staged
$pnpm_cmd lint
